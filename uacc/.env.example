# ─── LLM Configuration ────────────────────────────────────────
# Set one or more of these depending on which model you use.

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Any OpenAI-compatible endpoint (Ollama, vLLM, Together, Groq, etc.)
OPENAI_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=llama3.1:70b

# ─── UACC Settings ───────────────────────────────────────────
# Adapter mode: "text", "vision", "hybrid"
UACC_MODE=hybrid

# Grid resolution for vision models: "coarse", "medium", "fine", "micro"
UACC_GRID_MODE=medium

# Safety: require confirmation before destructive actions
UACC_SAFE_MODE=true

# Max iterations per agent task
UACC_MAX_ITERATIONS=30

# Human mimicry: enable Bézier curve mouse movement
UACC_HUMAN_MIMICRY=true

# Action delay (ms) between consecutive actions
UACC_ACTION_DELAY_MS=150

# Screenshot quality (1-100, lower = faster transfer to API)
UACC_SCREENSHOT_QUALITY=80

# ─── MCP Server Settings ─────────────────────────────────────
# Transport: "stdio" (Claude Code, Hermes, etc.) or "sse" or "streamable-http"
UACC_MCP_TRANSPORT=stdio

# Host to bind for SSE/HTTP transports
UACC_MCP_HOST=127.0.0.1

# Port for SSE/HTTP transports (ignored for stdio)
UACC_MCP_PORT=8765

# URL path for streamable-http transport
UACC_MCP_PATH=/mcp
